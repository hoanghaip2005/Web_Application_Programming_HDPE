NODE_ENV=development
PORT=4000
FRONTEND_ORIGIN=http://localhost:5173
APP_BASE_URL=http://localhost:4000
PGHOST=aws-1-ap-southeast-2.pooler.supabase.com
PGPORT=6543
PGDATABASE=postgres
PGUSER=postgres.project-ref
PGPASSWORD=your-password
PGSSLMODE=require
DB_CONNECTION_TIMEOUT_MS=15000
DB_QUERY_TIMEOUT_MS=30000
DB_STATEMENT_TIMEOUT_MS=30000
DB_POOL_MIN=1
DB_POOL_MAX=10
DB_POOL_CREATE_TIMEOUT_MS=15000
DB_POOL_ACQUIRE_TIMEOUT_MS=20000
DB_POOL_IDLE_TIMEOUT_MS=30000
JWT_SECRET=change-me
API_KEY=hdpe-local-api-key
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=avatars
# Optional HTTPS listener
HTTPS_PORT=4443
HTTPS_KEY_PATH=./certs/localhost-key.pem
HTTPS_CERT_PATH=./certs/localhost.pem
HTTPS_CA_PATH=
